<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechPilot - Gaming Gear & Accessories</title>
    <!-- FAVICON -->
    <link rel="icon" type="image/png" href="images/favicon.png" />

    <!-- Bootstrap 5 CDN Links -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

    <!-- Custom File's Link -->
    <link rel="stylesheet" href="css/style.css" />
    <link rel="stylesheet" href="css/responsive-style.css" />
</head>
<body>
    <%- include('includes/navbar') %>
    <form method="POST" action="/listings/<%= listing.product_code %>?_method=PUT">
        <h1>Edit Product</h1>

        <!-- Product Info -->
        <label for="name">Name:</label><br>
        <input type="text" id="name" name="listing[name]" value="<%= listing.name %>" required><br><br>

        <label for="category">Category:</label><br>
        <input type="text" id="category" name="listing[category]" value="<%= listing.category %>" required><br><br>

        <label for="short_description">Description:</label><br>
        <textarea id="short_description" name="listing[short_description]" rows="4" cols="50" required><%= listing.short_description %></textarea><br><br>

        <label for="image_url">Image URL:</label><br>
        <input type="text" id="image_url" name="listing[image_url]" value="<%= listing.image_url %>"><br><br>

        <!-- Product Details Info -->
        <label for="price">Price (BDT):</label><br>
        <input type="number" id="price" name="listing[price]" value="<%= listing.price %>" required><br><br>

        <label for="status">Status:</label><br>
        <select id="status" name="listing[status]" required>
            <option value="Available" <%= listing.status === 'Available' ? 'selected' : '' %>>Available</option>
            <option value="Out of Stock" <%= listing.status === 'Out of Stock' ? 'selected' : '' %>>Out of Stock</option>
            <option value="Discontinued" <%= listing.status === 'Discontinued' ? 'selected' : '' %>>Discontinued</option>
        </select><br><br>

        <label for="brand">Brand:</label><br>
        <input type="text" id="brand" name="listing[brand]" value="<%= listing.brand %>"><br><br>

        <label>Key Features:</label><br />
        <textarea name="listing[key_features]" rows="4" cols="50"><%= listing.key_features %></textarea><br /><br />

        <button type="submit">Update Product</button>
    </form>
    <%- include('includes/footer') %>
    <!-- Bootstrap 5 JS CDN Links -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom Js Link -->
    <script src="js/main.js"></script>
</body>
</html>
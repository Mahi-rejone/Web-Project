<% layout("/layouts/boilerplate") %>

<section class="edit_wrapper wrapper">
  <form method="POST"
        action="/listings/<%= listing.product_code %>?_method=PUT"
        class="needs-validation"
        novalidate>

    <div class="container">
      <h1 class="mb-4">Edit Product</h1>

      <div class="row">
        <div class="col-lg-8 mx-auto">

          <!-- Name -->
          <div class="mb-3">
            <label for="name" class="form-label"><p>Name:</p></label>
            <input type="text"
                   class="form-control"
                   id="name"
                   name="listing[name]"
                   value="<%= listing.name %>"
                   required>
          </div>

          <!-- Category -->
          <div class="mb-3">
            <label for="category" class="form-label"><p>Category:</p></label>
            <input type="text"
                   class="form-control"
                   id="category"
                   name="listing[category]"
                   value="<%= listing.category %>"
                   required>
          </div>

          <!-- Description -->
          <div class="mb-3">
            <label for="short_description" class="form-label"><p>Description:</p></label>
            <textarea id="short_description"
                      class="form-control"
                      name="listing[short_description]"
                      rows="4"
                      required><%= listing.short_description %></textarea>
          </div>

          <!-- Image URL -->
          <div class="mb-3">
            <label for="image_url" class="form-label"><p>Image URL:</p></label>
            <input type="text"
                   id="image_url"
                   class="form-control"
                   name="listing[image_url]"
                   value="<%= listing.image_url %>">
          </div>

          <!-- Price & Status SAME LINE -->
          <div class="row">
            <div class="col-md-6">
              <div class="mb-3">
                <label for="price" class="form-label"><p>Price (BDT):</p></label>
                <input type="number"
                       id="price"
                       class="form-control"
                       name="listing[price]"
                       value="<%= listing.price %>"
                       required>
              </div>
            </div>

            <div class="col-md-6">
              <div class="mb-3">
                <label for="status" class="form-label"><p>Status:</p></label>
                <select id="status"
                        name="listing[status]"
                        class="form-select"
                        required>
                  <option value="Available" <%= listing.status === 'Available' ? 'selected' : '' %>>
                    Available
                  </option>
                  <option value="Out of Stock" <%= listing.status === 'Out of Stock' ? 'selected' : '' %>>
                    Out of Stock
                  </option>
                  <option value="Discontinued" <%= listing.status === 'Discontinued' ? 'selected' : '' %>>
                    Discontinued
                  </option>
                </select>
              </div>
            </div>
          </div>

          <!-- Brand -->
          <div class="mb-3">
            <label for="brand" class="form-label"><p>Brand:</p></label>
            <input type="text"
                   class="form-control"
                   id="brand"
                   name="listing[brand]"
                   value="<%= listing.brand %>">
          </div>

          <!-- Key Features -->
          <div class="mb-3">
            <label for="key_features" class="form-label"><p>Key Features:</p></label>
            <textarea id="key_features"
                      class="form-control"
                      name="listing[key_features]"
                      rows="4"><%= listing.key_features %></textarea>
          </div>

          <!-- Button -->
          <button class="main-btn btn btn-dark" type="submit">
            Update Product
          </button>

        </div>
      </div>
    </div>

  </form>
</section>
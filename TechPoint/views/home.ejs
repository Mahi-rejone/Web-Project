              <h4>Good Price</h4>
              <p>Compeitive pricing withtout compromiseing on quality.</p>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 mb-4">
            <div class="common-card">
              <div class="card-icon">
                <i class="fas fa-download"></i>
              </div>
              <h4>Free Updates</h4>
              <p>Get free software & free updates for lifetime.</p>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 mb-4">
            <div class="common-card">
              <div class="card-icon">
                <i class="fas fa-headset"></i>
              </div>
              <h4>24/7 Support</h4>
              <p>Round tthe clock customer support for all needs.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- Services section Exit -->

    <!-- Facts section -->
    <section id="facts" class="facts_wrapper wrapper">
      <div class="container">
        <div class="section-title text-center mb-5">

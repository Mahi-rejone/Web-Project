<% layout("/layouts/boilerplate") %>
    <!-- Banner section -->
    <section id="home" class="banner_wrapper wrapper">
      <div class="container position-relative">
        <div class="vertical-text">PREMIUM GAMING GEAR</div>
        <div class="row align-items-center">
          <div class="col-lg-6 mb-lg-0 mb-5">
            <div class="banner_content">
              <h1>Welcome to TechPilot</h1>
              <h4>Unleash Your Gaming Potential with TechPilot</h4>
              <p>
                Discover the ultimate gaming experience with TechPilot's premium
                gear and accessories. Elevate your gameplay and dominate the
                competition.
              </p>
              <a href="/listings" class="banner-btn">
                <i class="fas fa-gamepad"></i> Explore Our Products
              </a>
              <div class="hero-badges">
                <span class="badge">
                  <i class="fas fa-shield-alt"></i>
                  Trusted by Gamers Worldwide
                </span>
                <span class="badge">
                  <i class="fas fa-trophy"></i>
                  Pro Gamer Approved
                </span>
                <span class="badge">
                  <i class="fas fa-bolt"></i>
                  Premium Quality
                </span>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div>
              <img src="./images/top-banner-img/mouse.png" class="img-fluid ms-xl-5" alt="Gaming Mouse" />
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- Banner section exit -->

    <!-- About section -->
    <section id="about" class="about_wrapper wrapper">
      <div class="container">
        <div class="section-title text-center mb-5">
          <h2>
            About
            <span class="highlight">TechPilot</span>
          </h2>
          <div class="title-design">
            <span class="line"></span>
            <i class="fas fa-gamepad"></i>
            <span class="line"></span>
          </div>
        </div>
        <div class="row">
          <div class="col-lg-6 mb-lg-0 mb-5">
            <div class="position-relative">
              <img src="./images/about/about-banner1.png" alt="#" class="img-fluid" />
            </div>
          </div>
          <div class="col-lg-6">
            <div class="common-card">
              <div class="card-icon">
                <i class="fas fa-rocket"></i>
              </div>
              <h4>Our Mission</h4>
              <p>
                Lorem ipsum dolor sit amet consectetur adipisicing elit.
                Recusandae, modi animi officiis totam soluta deleniti. Accusamus
                nulla ea, praesentium beatae quas illo. Deserunt omnis expedita
                doloribus assumenda mollitia. Perferendis, natus.
              </p>
            </div>
            <div class="hero-badges flex-wrap justify-content-start">
              <div class="badge">
                <i class="fas fa-check-circle"></i>
                Premium Quality Products
              </div>
              <div class="badge">
                <i class="fas fa-check-circle"></i>
                24/7 Customer Support
              </div>
              <div class="badge">
                <i class="fas fa-check-circle"></i>
                Fast Worldwide Shipping
              </div>
              <div class="badge">
                <i class="fas fa-check-circle"></i>
                5 Years Warrenty
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- About section exit -->

    <!-- Product section -->
    <section id="products" class="products_wrapper wrapper">
      <div class="container">
        <div class="section-title text-center mb-5">
          <h2>Featured <span class="highlight"> Gaming Gear</span></h2>
          <div class="title-design">
            <span class="line"></span>
            <i class="fas fa-keyboard"></i>
            <span class="line"></span>
          </div>
        </div>
        <div class="row product-slider">
          <% listings.forEach(listing=> { %>
            <div class="mb-4 ">
              <div class="card text-center p-3">
                <div class="product-img mb-4">
                  <img src="<%= listing.image_url %>" alt="<%= listing.name %>" class="img-fluid" />
                </div>
                <div class="text-center mb-4">
                  <p>
                    <%= listing.category %>
                  </p>
                  <h5>
                    <%= listing.name %>
                  </h5>
                  <h6 class="s_discription">
                    <%= listing.short_description %>
                  </h6>
                  <a href="/listings/<%= listing.product_code %>" class="main-btn mt-4">Read More</a>
                </div>
              </div>
            </div>
            <% }) %>
        </div>
      </div>
    </section>
    <!-- Products section Exit -->

    <!-- Ads section -->
    <div class="ads_wrapper wrapper">
      <div class="container">
        <div class="row">
          <div class="col-md-12">
            <div class="card">
              <div>
                <h2>Ultimet Gaming Bundle</h2>
                <p class="discount my-5">Save 30%</p>
                <p>
                  Lorem ipsum dolor sit amet consectetur adipisicing elit.
                  Tempora suscipit, molestiae nam aliquid tenetur quia autem
                  quas optio voluptates doloremque sequi amet quo veritatis,
                  consectetur ullam dolore vitae animi quis.
                </p>
                <a href="#products" class="main-btn mt-4">Shop Now</a>
              </div>
              <div class="ad-image col-lg-4">
                <img src="./images/ads/bundle-keyboard.png" alt="" class="img-fluid" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Ads Section Exit  -->

    <!-- Services section -->
    <section id="services" class="services_wrapper wrapper">
      <div class="container">
        <div class="section-title text-center mb-5">
          <h2>We Provide High Tech <span class="highlight">Products!</span></h2>
          <div class="title-design">
            <span class="line"></span>
            <i class="fas fa-shield-alt"></i>
            <span class="line"></span>

<% layout("/layouts/boilerplate") %>
<section class="message_wrapper wrapper">
  <h1>All User Messages</h1>
  <div message-table>
    <% if (messages && messages.length> 0) { %>
      <table>
        <thead>
          <tr>
            <th>Id</th>
            <th>Message</th>
            <th>Sent At</th>
          </tr>
        </thead>
        <tbody>
          <% messages.forEach((msg)=> { %>
            <tr>
              <td>
                <%= msg.id %>
              </td>
              <td>
                <%= msg.message %>
              </td>
              <td>
                <%= msg.created_at ? msg.created_at.toLocaleString() : "-" %>
              </td>
            </tr>
            <% }) %>
        </tbody>
      </table>
      <% } else { %>
        <p>No messages yet.</p>
        <% } %>
  </div>
</section>
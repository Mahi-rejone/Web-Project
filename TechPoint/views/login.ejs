<% layout("/layouts/boilerplate") %>
<section class="banner_wrapper wrapper">
    <div class="container position-relative">
        <div class="vertical-text">PREMIUM GAMING GEAR</div>
        <div class="row align-items-center">
            <div class="col-lg-6 mb-lg-0 mb-5">
                <form method="POST" action="/user/login" class="needs-validation" novalidate>
                    <div class="container">
                        <h1 class="mb-4">Log In</h1>
                        <div class="row">
                            <div class="col-lg-8 mx-auto">
                                <a href="/user/logout"></a>
                                <div class="mb-3">
                                    <label for="email" class="form-label">
                                        <p>Email:</p>
                                    </label>
                                    <input type="email" class="form-control" id="email" name="user[email]" required>
                                </div>
                                <div class="mb-3">
                                    <label for="password" class="form-label">
                                        <p>Password:</p>
                                    </label>
                                    <input type="password" class="form-control" id="password" name="user[password]"
                                        required>
                                </div>
                                <button class="main-btn btn btn-dark" type="submit">
                                    Log In
                                </button>
                            </div>
                            <div class="col-lg-8 mx-auto mt-3">
                                <p>
                                    If you don't have an account
                                    <a href="/user/signup" >
                                        Register Now
                                    </a>
                                </p> 
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="col-lg-6">
                <div>
                    <img src="./images/top-banner-img/mouse.png" class="img-fluid ms-xl-5" alt="Gaming Mouse" />
                </div>
            </div>
        </div>
    </div>
</section>
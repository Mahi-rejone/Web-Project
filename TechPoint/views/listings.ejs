<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechPilot - Gaming Gear & Accessories</title>
    <!-- FAVICON -->
    <link rel="icon" type="image/png" href="images/favicon.png" />

    <!-- Bootstrap 5 CDN Links -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

    <!-- Custom File's Link -->
    <link rel="stylesheet" href="css/style.css" />
    <link rel="stylesheet" href="css/responsive-style.css" />
</head>

<body>
    <%- include('includes/navbar') %>
    <section class="products_wrapper wrapper">
    <div class="container">
        <div class="section-title text-center mb-5">
        <h2>Featured <span class="highlight">Gaming Gear</span></h2>
        <div class="title-design">
            <span class="line"></span>
            <i class="fas fa-keyboard"></i>
            <span class="line"></span>
        </div>
        </div>

        <div class="row">
        <% listings.forEach(listing => { %>
            <div class="col-lg-3 col-md-6 mb-4">
            <div class="card text-center p-3">
                <div class="product-img mb-4">
                <img src="<%= listing.image_url %>" alt="<%= listing.name %>" class="img-fluid" />
                </div>
                <div class="text-center mb-4">
                <p><%= listing.category %></p>
                <h5><%= listing.name %></h5>
                <h6><%= listing.short_description %></h6>
                <a href="/listings/<%= listing.product_code %>" class="main-btn mt-4">Read More</a>
                </div>
            </div>
            </div>
        <% }) %>
        </div>
    </div>
    </section>
    <%- include('includes/footer') %>
    <!-- Bootstrap 5 JS CDN Links -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom Js Link -->
    <script src="js/main.js"></script>
</body>
</html>
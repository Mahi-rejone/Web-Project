<% layout("/layouts/boilerplate") %>

<section class="new_wrapper wrapper">
  <form method="POST"
        action="/listings"
        class="needs-validation"
        novalidate>

    <div class="container">
      <h1 class="mb-4">Create New Listing</h1>

      <div class="row">
        <div class="col-lg-8 mx-auto">
          <div class="mb-3">
            <label for="name" class="form-label"><p>Name:</p></label>
            <input type="text"
                   class="form-control"
                   id="name"
                   name="name"
                   required>
          </div>
          <div class="mb-3">
            <label for="category" class="form-label"><p>Category:</p></label>
            <input type="text"
                   class="form-control"
                   id="category"
                   name="category"
                   required>
          </div>
          <div class="mb-3">
            <label for="short_description" class="form-label"><p>Description:</p></label>
            <textarea id="short_description"
                      class="form-control"
                      name="short_description"
                      rows="4"
                      required></textarea>
          </div>
          <div class="mb-3">
            <label for="image_url" class="form-label"><p>Image URL:</p></label>
            <input type="text"
                   id="image_url"
                   class="form-control"
                   name="image_url">
          </div>
          <div class="row">
            <div class="col-md-6">
              <div class="mb-3">
                <label for="price" class="form-label"><p>Price (BDT):</p></label>
                <input type="number"
                       step="0.01"
                       id="price"
                       class="form-control"
                       name="price"
                       required>
              </div>
            </div>

            <div class="col-md-6">
              <div class="mb-3">
                <label for="status" class="form-label"><p>Status:</p></label>
                <select id="status"
                        name="status"
                        class="form-select"
                        required>
                  <option value="Available">Available</option>
                  <option value="Out of Stock">Out of Stock</option>
                  <option value="Discontinued">Discontinued</option>
                </select>
              </div>
            </div>
          </div>
          <div class="mb-3">
            <label for="brand" class="form-label"><p>Brand:</p></label>
            <input type="text"
                   class="form-control"
                   id="brand"
                   name="brand">
          </div>
          <div class="mb-3">
            <label for="key_features" class="form-label"><p>Key Features:</p></label>
            <textarea id="key_features"
                      class="form-control"
                      name="key_features"
                      rows="4"></textarea>
          </div>
          <button class="main-btn btn btn-dark" type="submit">
            Create Listing
          </button>

        </div>
      </div>
    </div>

  </form>
</section>
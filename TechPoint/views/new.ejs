<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TechPilot - Gaming Gear & Accessories</title>
    <!-- FAVICON -->
    <link rel="icon" type="image/png" href="images/favicon.png" />

    <!-- Bootstrap 5 CDN Links -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

    <!-- Custom File's Link -->
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/responsive-style.css" />
  </head>
  <body>

    <%- include('includes/navbar') %>
    <form method="post" action="/listings" class="needs-validation" novalidate>
      <h1>Create New Listing</h1>
      <!-- PRODUCTS TABLE DATA -->
      <label>Name:</label><br />
      <input type="text" name="name" required /><br /><br />

      <label>Category:</label><br />
      <input type="text" name="category" /><br /><br />

      <label>Short Description:</label><br />
      <textarea name="short_description" rows="4" cols="50"></textarea
      ><br /><br />

      <label>Image URL:</label><br />
      <input type="text" name="image_url" /><br /><br />

      <!-- PRODUCT DETAILS TABLE DATA -->
      <label>Price (BDT):</label><br />
      <input type="number" step="0.01" name="price" required /><br /><br />

      <label>Status:</label><br />
      <select name="status">
        <option value="Available">Available</option>
        <option value="Out of Stock">Out of Stock</option>
        <option value="Discontinued">Discontinued</option></select
      ><br /><br />

      <label>Brand:</label><br />
      <input type="text" name="brand" /><br /><br />

      <label>Key Features:</label><br />
      <textarea name="key_features" rows="4" cols="50"></textarea><br /><br />

      <button type="submit">Create Listing</button>
    </form>
    <%- include('includes/footer') %>
    <!-- Bootstrap 5 JS CDN Links -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom Js Link -->
    <script src="js/main.js"></script>
  </body>
</html>

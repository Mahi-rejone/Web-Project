<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TechPilot - Gaming Gear & Accessories</title>
    <!-- FAVICON -->
    <link rel="icon" type="image/png" href="/images/favicon.png" />

    <!-- Bootstrap 5 CDN Links -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"
    />

    <!-- Custom File's Link -->
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/show.css" />
    <link rel="stylesheet" href="/css/responsive-style.css" />
  </head>

  <body>
    <%- include('includes/navbar') %>
    <section class="item_Werapper wrapper show">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-5 item-img ">
            <div class="pe-lg-5">
              <img
                src="<%= listing.image_url %>"
                class="img-fluid ms-xl-5"
                alt="Gaming Mouse"
              />
            </div>
          </div>
          <div class="col-lg-7 mb-lg-0 mb-5 ps-lg-5">
            <div class="banner_content">
              <h1 style="padding-top: 2rem;"><%= listing.name %></h1>
              <div class="hero-badges" style="padding-bottom: 2rem;">
                <span class="badge">
                  <span class="highlight">Price :</span> &#2547; <%= listing.price %>
                </span>
                <span class="badge">
                  <span class="highlight">Status : </span><%= listing.status %>
                </span>
                <span class="badge">
                  <span class="highlight">Brand : </span><%= listing.brand %> 
                </span>
              </div>
              <h4><%= listing.short_description %></h4>
              <p>
               <%=listing.key_features%> Lorem ipsum dolor sit amet consectetur adipisicing elit.
                Recusandae, modi animi officiis totam soluta deleniti. Accusamus
                nulla ea, praesentium beatae quas illo. Deserunt omnis expedita
                doloribus assumenda mollitia. Perferendis, natus.
              </p>
              <a href="#" class="banner-btn">
                <i class="fas fa-cart-arrow-down"></i> Buy Now
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <%- include('includes/footer') %>
    <!-- Bootstrap 5 JS CDN Links -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom Js Link -->
    <script src="js/main.js"></script>
  </body>
</html>

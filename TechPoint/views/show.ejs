<% layout("/layouts/boilerplate") %>
<section class="item_Werapper wrapper show">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-5 item-img ">
        <div class="pe-lg-5">
          <img src="<%= listing.image_url %>" class="img-fluid ms-xl-5" alt="Gaming Mouse" />
        </div>
      </div>
      <div class="col-lg-7 mb-lg-0 mb-5 ps-lg-5">
        <div class="banner_content">
          <h1 style="padding-top: 2rem;">
            <%= listing.name %>
          </h1>
          <div class="hero-badges" style="padding-bottom: 2rem;">
            <span class="badge">
              <span class="highlight">Price :</span> &#2547; <%= listing.price %>
            </span>
            <span class="badge">
              <span class="highlight">Status : </span>
              <%= listing.status %>
            </span>
            <span class="badge">
              <span class="highlight">Brand : </span>
              <%= listing.brand %>
            </span>
          </div>
          <h4>
            <%= listing.short_description %>
          </h4>
          <p>
            <%=listing.key_features%> Lorem ipsum dolor sit amet consectetur adipisicing elit.
              Recusandae, modi animi officiis totam soluta deleniti. Accusamus
              nulla ea, praesentium beatae quas illo. Deserunt omnis expedita
              doloribus assumenda mollitia. Perferendis, natus.
          </p>
          <div>
            <a href="#" class="banner-btn">
              <i class="fas fa-cart-arrow-down"></i> Buy Now
            </a>
            <form method="POST" action="/listings/<%= listing.product_code %>?_method=DELETE">
              <button class="banner-btn" type="submit">Delete Listing</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
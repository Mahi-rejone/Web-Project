<% layout("/layouts/boilerplate") %>

    <form method="post" action="/listings">
        <h1>Create New Listing</h1>
        <label for="title">Title:</label><br>
        <input type="text" id="title" name="listing[title]" required><br><br>

        <label for="description">Description:</label><br>
        <textarea id="description" name="listing[description]" rows="4" cols="50" required></textarea><br><br>

        <label for="image">Image URL:</label><br>
        <input type="text" id="image" name="listing[image]"><br><br>

        <label for="price">Price (in BDT):</label><br>
        <input type="number" id="price" name="listing[price]" required><br><br>

        <label for="location">Location:</label><br>
        <input type="text" id="location" name="listing[location]" required><br><br>

        <label for="country">Country:</label><br>
        <input type="text" id="country" name="listing[country]" required><br><br>

        <button type="submit">Create Listing</button>
    </form>

